ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda/bin/nvcc

cflags = -pthread -B /opt/conda/envs/nova3r/compiler_compat -fno-strict-overflow -Wsign-compare -DNDEBUG -O2 -Wall -fPIC -O2 -isystem /opt/conda/envs/nova3r/include -fPIC -O2 -isystem /opt/conda/envs/nova3r/include -fPIC -I/opt/conda/envs/nova3r/lib/python3.12/site-packages/torch/include -I/opt/conda/envs/nova3r/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -I/usr/local/cuda/include -I/opt/conda/envs/nova3r/include/python3.12 -c
post_cflags = -O3 -DTORCH_API_INCLUDE_EXTENSION_H -DTORCH_EXTENSION_NAME=curope -std=c++17
cuda_cflags = -I/opt/conda/envs/nova3r/lib/python3.12/site-packages/torch/include -I/opt/conda/envs/nova3r/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -I/usr/local/cuda/include -I/opt/conda/envs/nova3r/include/python3.12 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -O3 --ptxas-options=-v --use_fast_math -gencode arch=compute_75,code=sm_75 -gencode arch=compute_80,code=sm_80 -gencode arch=compute_86,code=sm_86 -gencode arch=compute_90,code=sm_90 -gencode arch=compute_100,code=sm_100 -gencode arch=compute_120,code=sm_120 -DTORCH_API_INCLUDE_EXTENSION_H -DTORCH_EXTENSION_NAME=curope -std=c++17
cuda_dlink_post_cflags = 
sycl_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc -MD -MF $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags







build /mnt/home/vyhong/projects/nova3r/croco/models/curope/build/temp.linux-x86_64-cpython-312/curope.o: compile /mnt/home/vyhong/projects/nova3r/croco/models/curope/curope.cpp
build /mnt/home/vyhong/projects/nova3r/croco/models/curope/build/temp.linux-x86_64-cpython-312/kernels.o: cuda_compile /mnt/home/vyhong/projects/nova3r/croco/models/curope/kernels.cu








